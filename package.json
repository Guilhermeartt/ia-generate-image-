{
  "name": "v2-_artt_gerador_de_imagem",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/geminiProxy.mjs",
    "dev:sam2": "uvicorn server.sam2_service:app --host 127.0.0.1 --port 8791",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "dev:full:sam2": "concurrently \"npm run dev:sam2\" \"npm run dev:api\" \"npm run dev\"",
    "build": "vite build",
    "preview": "npm run build && node server/geminiProxy.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.8"
  }
}
