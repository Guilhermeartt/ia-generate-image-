# Vycena — variáveis de ambiente
# Copie para .env.local e ajuste. Não comitar valores reais.

# ── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=8787

# URL pública usada por CORS e por links em e-mails.
# Em prod: https://seudominio.com.br
PUBLIC_URL=http://localhost:3000

# ── Segredos da aplicação (gere com: openssl rand -hex 32) ──────────────────
APP_SECRET=dev-secret-change-me
APP_ENCRYPTION_KEY=dev-encryption-change-me

# E-mails que ganham acesso admin (lista separada por vírgula)
ADMIN_EMAILS=guilherme.artt@gmail.com

# ── Banco de dados (Fase 1) ─────────────────────────────────────────────────
# Em dev usamos SQLite local (data/saas.sqlite). Em prod, definir DATABASE_URL.
# DATABASE_URL=postgres://vycena:senha@127.0.0.1:5432/vycena

# ── Provider Gemini (escolha um) ────────────────────────────────────────────
# AI Studio (mais simples):
GEMINI_API_KEY=AIza...

# Vertex AI Express (alternativa):
# VERTEX_API_KEY=...

# Vertex AI com service account:
# GOOGLE_APPLICATION_CREDENTIALS=/etc/vycena/sa.json
# GOOGLE_CLOUD_PROJECT=vycenaapp
# GOOGLE_CLOUD_LOCATION=us-central1

# Conversão USD → BRL usada no cálculo de custos (valor padrão: 5.80)
USD_TO_BRL=5.80

# ── Stripe (Fase 3) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email transacional (Fase 2) ─────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@seudominio.com.br

# ── Observabilidade (Fase 4) ────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Flags ────────────────────────────────────────────────────────────────────
# Em dev você pode pular verificação de e-mail para testar billing.
REQUIRE_EMAIL_VERIFICATION=1
# Em dev você pode logar bodies de request (cuidado: pode vazar PII).
# LOG_BODIES=0
